{
  "name": "@supanow/js",
  "version": "0.1.0",
  "description": "The supanow client library for JavaScript/TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~6.0.0"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hectoropenclaw/supanow.git",
    "directory": "packages/js"
  },
  "keywords": ["supabase", "postgres", "database", "realtime", "storage", "functions"]
}
