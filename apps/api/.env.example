# Control plane PostgreSQL (standalone, not a project DB)
DATABASE_URL=postgresql://postgres:password@localhost:5433/mysuperdatabase_cp

# NextAuth.js
AUTH_SECRET=         # openssl rand -hex 32
NEXTAUTH_URL=https://api.mysuperdatabase.com

# OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public API base URL (used by Studio)
NEXT_PUBLIC_API_URL=https://api.mysuperdatabase.com
